# --- Wrapline environment ---

# WalletConnect / RainbowKit project id (get one at https://cloud.reown.com).
# Injected wallets (MetaMask) work without it; WalletConnect needs a real id.
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional custom RPC endpoints. Leave blank to use public chain defaults.
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_MAINNET_RPC_URL=
